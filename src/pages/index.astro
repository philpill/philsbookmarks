---

import '../styles/global.css';

// src/pages/index.astro
import { GoogleSpreadsheet } from 'google-spreadsheet';

const SPREADSHEET_ID = import.meta.env.GOOGLE_SHEET_ID;

// 1. Initialize the document
const doc = new GoogleSpreadsheet(SPREADSHEET_ID, {
  apiKey: import.meta.env.GOOGLE_API_KEY // If using an API key for public sheets
});

// 2. Load the sheet info
await doc.loadInfo(); 
const sheet = doc.sheetsByIndex[2]; // Get the first sheet

// 3. Fetch rows
const rows = await sheet.getRows();

// 4. Group rows by tag
const groupedByTag = rows.reduce((acc: any, row) => {
  const tag = row.get('tag');
  if (!acc[tag]) {
    acc[tag] = [];
  }
  acc[tag].push(row);
  return acc;
}, {});

// Sort tags alphabetically
const sortedTags = Object.keys(groupedByTag).sort();
---

<html lang="en">
  <head>
    <title>bookmarks</title>
  </head>
  <body class="p-2 text-slate-700 dark:bg-gray-800 dark:text-slate-300">

    <header class="mb-2">
        <h1><a href="http://philshum.co.uk">philshum.co.uk</a></h1>
        <h2><a href="/">bookmarks</a></h2>
    </header>
    <div class="mb-10 columns-1 gap-2 xs:columns-1 sm:columns-1 md:columns-1 lg:columns-3 xl:columns-4 2xl:columns-5">
        {sortedTags.map((tag) => (
        <div class="mb-2 lg:mb-4 xl:mb-6 2xl:mb-8">
            <h2 class="font-bold">{tag}</h2>
            <ul>
            {groupedByTag[tag].map((row: any) => (
                <li>
                    <a class="hover:underline"
                        href={row.get('url')}>
                        {row.get('title')}
                    </a>
                </li>
            ))}
            </ul>
        </div>
        ))}
    </div>
  </body>
</html>
